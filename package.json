    "cpy-cli": "^7.0.0",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "gh-pages": "^6.3.0",
    "globals": "^16.3.0",
    "typescript": "^6.0.2",
    "typescript-plugin-css-modules": "^5.2.0",
    "vite": "^7.0.4"
